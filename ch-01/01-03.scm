#lang sicp

(define (square a) (* a a))
(define (sum-square a b) (+ (square a) (square b)))
(define (fun a b c)
    (if (> a b)
        (if (> b c)
            (sum-square a b)
            (sum-square a c)
        )
        (if (> a c)
            (sum-square a b)
            (sum-square b c)
        )
    )
)

(= (fun 10 10 10) 200)
(= (fun 1 10 10) 200)
(= (fun 10 1 10) 200)
(= (fun 10 10 1) 200)
(= (fun 1 10 100) 10100)
